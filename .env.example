# 환경 변수 예시 파일
# 이 파일을 복사하여 .env 파일을 생성하고 실제 값으로 변경하세요

# OpenAI API 키 (필수) - 이슈보고 생성 및 '기사 요약' 기능에 사용
OPEN_API_KEY=your_openai_api_key_here
# OPENAI_GPT_MODEL=gpt-4o-mini    # (선택) 요약/생성 모델 지정

# (선택) Google Gemini API 키 - 설정 시 '기사 요약'을 무료 Gemini로 우선 처리, 실패 시 OpenAI 폴백
# 발급: https://aistudio.google.com/apikey  (무료 티어 1,500회/일)
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Naver API 키 (뉴스 검색에 필요)
NAVER_CLIENT_ID=your_naver_client_id_here
NAVER_CLIENT_SECRET=your_naver_client_secret_here

# 텔레그램 봇 설정 (선택사항 - 뉴스 알림 기능)
# 설정 방법: KAKAO_WEBHOOK_SETUP.md 참조
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
